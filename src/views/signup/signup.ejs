    <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign up for X</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'x-black': '#000000',
                        'x-white': '#ffffff',
                        'x-gray': '#71767b',
                        'x-dark-gray': '#202327',
                        'x-border': '#2f3336',
                        'x-blue': '#1d9bf0',
                        'x-blue-hover': '#1a8cd8',
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
        .input-field {
            width: 100%;
            padding: 20px 0 8px 0;
            background: transparent;
            border: none;
            border-bottom: 1px solid #2f3336;
            color: #fff;
            font-size: 16px;
            outline: none;
        }
        .input-field:focus {
            border-bottom: 1px solid #1d9bf0;
        }
        .input-field::placeholder {
            color: #71767b;
        }
        .select-field {
            width: 100%;
            padding: 20px 0 8px 0;
            background: transparent;
            border: none;
            border-bottom: 1px solid #2f3336;
            color: #fff;
            font-size: 16px;
            outline: none;
        }
        .select-field:focus {
            border-bottom: 1px solid #1d9bf0;
        }
        .select-field option {
            background: #000;
            color: #fff;
        }
    </style>
</head>
<body class="text-x-white min-h-screen bg-x-black">
    <div class="flex min-h-screen">
        <!-- Left Side - X Logo -->
        <div class="hidden md:flex md:flex-[0.5] lg:flex-[0.4] items-center justify-center p-10">
            <svg class="w-64 h-64 fill-x-white" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
            </svg>
        </div>

        <!-- Right Side - Signup Form -->
        <div class="flex-1 flex flex-col items-center justify-center p-5">
            <div class="w-full max-w-[400px]">
                <!-- X Logo for mobile -->
                <svg class="w-10 h-10 fill-x-white md:hidden mb-6" viewBox="0 0 24 24">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
                </svg>

                <h1 class="text-[31px] font-bold mb-8">Create your account</h1>

                <form id="signupForm" class="space-y-2">
                    <!-- Display Name -->
                    <div class="relative">
                        <input type="text" id="display_name" name="display_name" required
                            class="input-field peer" placeholder=" ">
                        <label for="display_name" class="absolute left-0 top-4 text-x-gray pointer-events-none transition-all duration-200 peer-focus:-translate-y-4 peer-focus:text-x-blue peer-focus:text-xs peer-[:not(:placeholder-shown)]:-translate-y-4 peer-[:not(:placeholder-shown)]:text-xs">
                            Display Name
                        </label>
                    </div>

                    <!-- Email -->
                    <div class="relative mt-4">
                        <input type="email" id="email" name="email" required
                            class="input-field peer" placeholder=" ">
                        <label for="email" class="absolute left-0 top-4 text-x-gray pointer-events-none transition-all duration-200 peer-focus:-translate-y-4 peer-focus:text-x-blue peer-focus:text-xs peer-[:not(:placeholder-shown)]:-translate-y-4 peer-[:not(:placeholder-shown)]:text-xs">
                            Email
                        </label>
                    </div>

                    <!-- Username -->
                    <div class="relative mt-4">
                        <input type="text" id="username" name="username" required
                            class="input-field peer" placeholder=" ">
                        <label for="username" class="absolute left-0 top-4 text-x-gray pointer-events-none transition-all duration-200 peer-focus:-translate-y-4 peer-focus:text-x-blue peer-focus:text-xs peer-[:not(:placeholder-shown)]:-translate-y-4 peer-[:not(:placeholder-shown)]:text-xs">
                            Username
                        </label>
                    </div>

                    <!-- Password -->
                    <div class="relative mt-4">
                        <input type="password" id="password" name="password" required
                            class="input-field peer" placeholder=" ">
                        <label for="password" class="absolute left-0 top-4 text-x-gray pointer-events-none transition-all duration-200 peer-focus:-translate-y-4 peer-focus:text-x-blue peer-focus:text-xs peer-[:not(:placeholder-shown)]:-translate-y-4 peer-[:not(:placeholder-shown)]:text-xs">
                            Password
                        </label>
                    </div>

                    <!-- Date of Birth -->
                    <div class="relative mt-4">
                        <input type="date" id="dob" name="dob" required
                            class="input-field peer" placeholder=" ">
                        <label for="dob" class="absolute left-0 top-4 text-x-gray pointer-events-none transition-all duration-200 peer-focus:-translate-y-4 peer-focus:text-x-blue peer-focus:text-xs peer-[:not(:placeholder-shown)]:-translate-y-4 peer-[:not(:placeholder-shown)]:text-xs">
                            Date of Birth
                        </label>
                    </div>

                    <!-- Country Dropdown -->
                    <div class="relative mt-4">
                        <select id="country" name="country" required class="select-field">
                            <option value="" disabled selected>Select your country</option>
                            <option value="US">United States</option>
                            <option value="GB">United Kingdom</option>
                            <option value="CA">Canada</option>
                            <option value="AU">Australia</option>
                            <option value="IN">India</option>
                            <option value="DE">Germany</option>
                            <option value="FR">France</option>
                            <option value="JP">Japan</option>
                            <option value="BR">Brazil</option>
                            <option value="MX">Mexico</option>
                            <option value="ES">Spain</option>
                            <option value="IT">Italy</option>
                            <option value="NL">Netherlands</option>
                            <option value="SE">Sweden</option>
                            <option value="NO">Norway</option>
                            <option value="DK">Denmark</option>
                            <option value="FI">Finland</option>
                            <option value="BE">Belgium</option>
                            <option value="CH">Switzerland</option>
                            <option value="AT">Austria</option>
                            <option value="IE">Ireland</option>
                            <option value="NZ">New Zealand</option>
                            <option value="SG">Singapore</option>
                            <option value="HK">Hong Kong</option>
                            <option value="KR">South Korea</option>
                            <option value="ZA">South Africa</option>
                            <option value="AE">United Arab Emirates</option>
                            <option value="SA">Saudi Arabia</option>
                            <option value="EG">Egypt</option>
                            <option value="NG">Nigeria</option>
                            <option value="KE">Kenya</option>
                            <option value="AR">Argentina</option>
                            <option value="CL">Chile</option>
                            <option value="CO">Colombia</option>
                            <option value="PE">Peru</option>
                            <option value="VE">Venezuela</option>
                            <option value="PL">Poland</option>
                            <option value="RU">Russia</option>
                            <option value="UA">Ukraine</option>
                            <option value="TR">Turkey</option>
                            <option value="IL">Israel</option>
                            <option value="ID">Indonesia</option>
                            <option value="MY">Malaysia</option>
                            <option value="PH">Philippines</option>
                            <option value="TH">Thailand</option>
                            <option value="VN">Vietnam</option>
                            <option value="PK">Pakistan</option>
                            <option value="BD">Bangladesh</option>
                            <option value="LK">Sri Lanka</option>
                            <option value="NP">Nepal</option>
                        </select>
                    </div>

                    <!-- Captcha -->
                    <div class="mt-6 p-4 border border-x-border rounded-lg bg-[#15202b]">
                        <p class="text-x-white text-sm mb-3 font-bold">Security Check</p>
                        <div class="flex items-center gap-4">
                            <img id="captchaImage" src="" alt="Captcha" class="h-12 border border-x-border rounded">
                            <button type="button" id="refreshCaptcha" class="text-x-blue hover:text-x-blue-hover text-sm font-semibold">
                                ↻
                            </button>
                        </div>
                        <input type="text" id="captchaText" name="captchaText" required
                            class="input-field mt-3" placeholder="Enter the characters above">
                        <input type="hidden" id="captchaId" name="captchaId">
                    </div>

                    <!-- Sign Up Button -->
                    <button type="submit" id="signupBtn"
                        class="w-full mt-6 rounded-full bg-x-white text-x-black font-bold text-[17px] py-3 px-4 transition-colors ">
                        Create account
                    </button>
                </form>

                <div class="mt-8 text-x-gray text-[15px]">
                    Already have an account? <a href="/auth/signin" class="text-x-blue no-underline hover:underline">Sign in</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        let captchaId = '';
        let captchaData = '';

        // Fetch captcha on page load
        async function loadCaptcha() {
            try {
                const response = await fetch('/auth/captcha');
                const data = await response.json();
                captchaId = data.captchaId;
                captchaData = data.captcha;
                document.getElementById('captchaImage').src = captchaData;
                document.getElementById('captchaId').value = captchaId;
            } catch (error) {
                console.error('Error loading captcha:', error);
            }
        }

        // Refresh captcha
        document.getElementById('refreshCaptcha').addEventListener('click', loadCaptcha);

        // Load captcha on page load
        loadCaptcha();

        // Enable/disable submit button based on form validity
        const form = document.getElementById('signupForm');
        const submitBtn = document.getElementById('signupBtn');

        form.addEventListener('input', function() {
            const display_name = document.getElementById('display_name').value;
            const email = document.getElementById('email').value;
            const username = document.getElementById('username').value;
            const password = document.getElementById('password').value;
            const dob = document.getElementById('dob').value;
            const country = document.getElementById('country').value;
            const captchaText = document.getElementById('captchaText').value;
        });

        // Form submission
        form.addEventListener('submit', async function(e) {
            e.preventDefault();

            const submitBtn = document.getElementById('signupBtn');
            // submitBtn.disabled = true;
            submitBtn.textContent = 'Creating account...';

            const formData = {
                display_name: document.getElementById('display_name').value,
                email: document.getElementById('email').value,
                username: document.getElementById('username').value,
                password: document.getElementById('password').value,
                dob: document.getElementById('dob').value,
                country: document.getElementById('country').value,
                captchaId: document.getElementById('captchaId').value,
                captchaText: document.getElementById('captchaText').value
            };

            try {
                const response = await fetch('/auth/signup', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });

                const result = await response.json();

                if (response.ok) {
                    showSuccess('Account created! Redirecting to sign in...');
                    setTimeout(() => window.location.href = '/auth/signin', 1200);
                } else {
                    showError(result.message || 'Error creating account');
                    loadCaptcha();
                    document.getElementById('captchaText').value = '';
                }
            } catch (error) {
                console.error('Error:', error);
                showError('Network error. Please try again.');
            }

            submitBtn.textContent = 'Create account';
            submitBtn.disabled = false;
        });

        function showError(msg) {
            let el = document.getElementById('signup-msg');
            if (!el) {
                el = document.createElement('div');
                el.id = 'signup-msg';
                document.getElementById('signupBtn').insertAdjacentElement('afterend', el);
            }
            el.className = 'mt-4 p-3 rounded-lg bg-red-900/30 border border-red-500 text-red-400 text-sm';
            el.textContent = msg;
        }
        function showSuccess(msg) {
            let el = document.getElementById('signup-msg');
            if (!el) {
                el = document.createElement('div');
                el.id = 'signup-msg';
                document.getElementById('signupBtn').insertAdjacentElement('afterend', el);
            }
            el.className = 'mt-4 p-3 rounded-lg bg-green-900/30 border border-green-500 text-green-400 text-sm';
            el.textContent = msg;
        }
    </script>
</body>
</html>
