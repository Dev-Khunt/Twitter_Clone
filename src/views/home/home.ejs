</head>

<body class="text-white">

<div class="flex max-w-[1400px] mx-auto">

  <!-- LEFT SIDEBAR -->
 <div id="sidebar" class="hidden md:block"></div>


  <!-- FEED CENTER -->
  <div class="flex-1 border-x border-gray-800 max-w-[600px]">

    <!-- Header -->
    <div class="sticky top-0 bg-black border-b border-gray-800 p-4 font-bold text-lg">
      Home
    </div>
    <!-- 🔍 SEARCH BAR -->
<div class="p-4 border-b border-gray-800 relative">

  <input
    id="searchInput"
    type="text"
    placeholder="Search"
    class="w-full p-3 rounded-full bg-[#202327] outline-none"
  />

  <!-- SEARCH RESULTS -->
  <div id="searchResults"
       class="absolute top-[60px] left-4 right-4 bg-black border border-gray-800 rounded-xl hidden max-h-[400px] overflow-y-auto z-50">
  </div>

</div>

    <!-- Tweet Box -->
   <div class="border-b border-gray-800 p-4 flex space-x-3">

  <!-- Profile -->
  <img src="https://ui-avatars.com/api/?name=User"
       class="w-10 h-10 rounded-full"/>

  <div class="w-full">

    <!-- TEXT -->
    <textarea id="tweetInput"
      class="w-full bg-black outline-none text-lg resize-none"
      placeholder="What is happening?!"></textarea>

    <!-- IMAGE PREVIEW -->
    <div id="previewContainer" class="mt-3 hidden">
      <img id="previewImage" class="rounded-xl max-h-[300px]"/>
    </div>

    <!-- ACTIONS -->
    <div class="flex justify-between items-center mt-3">

      <!-- FILE INPUT -->
      <label class="cursor-pointer text-[#1d9bf0] text-xl">
        📷
        <input type="file" id="fileInput" class="hidden"/>
      </label>

      <!-- POST BUTTON -->
      <button id="postBtn"
        class="bg-[#1d9bf0] px-5 py-2 rounded-full font-bold hover:bg-[#1a8cd8]">
        Post
      </button>

    </div>
  </div>
</div>
<br>
    <!-- Tweets -->
    <div id="feed"></div>

  </div>


  <!-- RIGHT SIDEBAR -->
  <div class="w-[350px] p-4 hidden lg:block">

    <!-- Search -->
    <input
      type="text"
      placeholder="Search"
      class="w-full p-3 rounded-full bg-[#202327] outline-none"
    />

    <!-- Trends -->
    <div class="bg-[#16181c] rounded-xl mt-4 p-4">
      <h2 class="text-xl font-bold mb-4">What’s happening</h2>

      <div class="space-y-3 text-sm text-gray-400">
        <p>#Technology</p>
        <p>#AI</p>
        <p>#Startups</p>
        <p>#Coding</p>
      </div>
    </div>

  </div>

</div>


<!-- SCRIPT -->
  <script>
const token = localStorage.getItem("accessToken");
// const token = req.headers.authorization.split(' ')[1]; 
console.log(token);

let selectedFile = null;

// 📷 FILE SELECT
document.getElementById("fileInput").addEventListener("change", (e) => {
  const file = e.target.files[0];
  if (!file) return;

  selectedFile = file;

  // Preview
  const preview = document.getElementById("previewImage");
  const container = document.getElementById("previewContainer");

  preview.src = URL.createObjectURL(file);
  container.classList.remove("hidden");
});


// 🚀 POST TWEET
document.getElementById("postBtn").addEventListener("click", async () => {
  const content = document.getElementById("tweetInput").value.trim();

  if (!content && !selectedFile) {
    alert("Tweet cannot be empty");
    return;
  }

  const formData = new FormData();
  formData.append("content", content);

  // IMPORTANT: backend expects "tweet"
  if (selectedFile) {
    formData.append("tweet", selectedFile);
  }

  try {
    const res = await fetch("/tweets", {
      method: "POST",
      headers: {
        "Authorization": "Bearer " + token
      },
      body: formData
    });

    const data = await res.json();

    // Reset UI
    document.getElementById("tweetInput").value = "";
    document.getElementById("previewContainer").classList.add("hidden");
    selectedFile = null;

    // Reload feed
    loadFeed();

  } catch (err) {
    console.error("Tweet error:", err);
  }
});

// jwt.verify(token, secret);

// Format time (like X: 1h, 2m etc.)
function formatTime(dateString) {
  if (!dateString) return "";

  let date = new Date(dateString);
  const now = new Date();
  
  const diffMs = now - date;
  
// Clamp negative/future → 0s
  
  const diffSecs = Math.floor(diffMs / 1000);
  const diffMins = Math.floor(diffMs / 60e3);
  const diffHours = Math.floor(diffMs / 36e5);
  const diffDays = Math.floor(diffMs / 864e5);

  if (isNaN(date.getTime())) {
    console.error("Invalid date:", dateString);
    return "";
  }

  if (diffSecs < 60) return `${Math.max(0, diffSecs)}s`;
  if (diffMins < 60) return `${Math.max(0, diffMins)}m`;
  if (diffHours < 24) return `${Math.max(0, diffHours)}h`;
  if (diffDays < 7) return `${Math.max(0, diffDays)}d`;

  return date.toLocaleDateString("en-US", { 
    month: 'short', 
    day: 'numeric' 
  });
}

// LOAD FEED
async function loadFeed() {
  try {
    const res = await fetch("/tweets/feed", {
      headers: {
        "Authorization": "Bearer " + token
      }
    });

    const tweets = await res.json();
    const feed = document.getElementById("feed");
    feed.innerHTML = "";
    console.log(tweets);

    tweets.forEach(tweet => {
      console.log("RAW DATE:", tweet.created_at);
console.log("PARSED:", new Date(tweet.created_at));
      console.log(tweet);
      if (!tweet.tweet_id) {
  console.error("Invalid tweet:", tweet);
  return;
}
      
      const div = document.createElement("div");
      div.onclick = (e) => {
  // Prevent click when clicking like/retweet buttons
  if (e.target.closest("button") || e.target.closest("span")) return;

  window.location.href = `/api/tweet/${tweet.tweet_id}`;
};
      div.className = "border-b border-gray-800 p-4 flex space-x-3 hover:bg-[#080808]";

      const isLikedClass = tweet.isLiked ? "text-red-500" : "";
      const isRetweetedClass = tweet.isRetweeted ? "text-green-500" : "";

      div.innerHTML = `
        <img src="${tweet.profile_image || 'https://ui-avatars.com/api/?name=' + tweet.username}"
     class="w-10 h-10 rounded-full"/>

        <div class="w-full">

          ${tweet.type === "retweet" ? `
            <div class="text-xs text-gray-500 mb-1">
              🔁 Retweeted
            </div>
          ` : ""}

          <!-- HEADER -->
          <div class="flex justify-between">
            <div>
              <span class="font-bold cursor-pointer hover:underline"
      onclick="goToProfile('${tweet.username}')">
  ${tweet.display_name}
</span>

<span class="text-gray-500 ml-1 cursor-pointer hover:underline"
      onclick="goToProfile('${tweet.username}')">
  @${tweet.username}
</span>
              <span class="text-gray-500 ml-1"> ${formatTime(tweet.created_at)}</span>
            </div>
          </div>

          <!-- CONTENT -->
          <p class="mt-2 text-sm">${tweet.content || ""}</p>

          <!-- MEDIA -->
          ${tweet.media_url ? `
            <img src="${tweet.media_url}" 
                 class="mt-3 rounded-xl max-h-[400px] w-full object-cover"/>
          ` : ""}

          <!-- ACTIONS -->
          <div class="flex justify-between mt-3 text-gray-500 text-sm max-w-[400px]">

  <!-- Retweet -->
  <div onclick="handleRetweet(this, ${tweet.tweet_id}, ${tweet.retweet_count}, ${tweet.isRetweeted})"
       class="flex items-center gap-1 cursor-pointer ${tweet.isRetweeted ? 'text-green-500' : ''}">
    🔁 <span>${tweet.retweet_count}</span>
  </div>

  <!-- Like -->
  <div onclick="handleLike(this, ${tweet.tweet_id}, ${tweet.like_count}, ${tweet.isLiked})"
       class="flex items-center gap-1 cursor-pointer ${tweet.isLiked ? 'text-red-500' : ''}">
    ❤️ <span>${tweet.like_count}</span>
  </div>

</div>
        </div>
      `;

      feed.appendChild(div);
    });
    

  } catch (err) {
    console.error("Feed error:", err);
  }
}


async function handleLike(el, tweetId, count, isLiked) {
  const token = localStorage.getItem("accessToken");
  const countEl = el.querySelector("span");

  try {
    if (isLiked) {
      // UNLIKE
      await fetch(`/reactions/tweets/${tweetId}`, {
        method: "DELETE",
        headers: {
          "Authorization": "Bearer " + token
        }
      });

      countEl.innerText = Number(count) - 1;
      el.classList.remove("text-red-500");

      // update attribute
      el.setAttribute("onclick",
        `handleLike(this, ${tweetId}, ${count - 1}, false)`
      );

    } else {
      // LIKE
      await fetch(`/reactions/tweets/${tweetId}`, {
        method: "POST",
        headers: {
          "Authorization": "Bearer " + token
        }
      });

      countEl.innerText = Number(count) + 1;
      el.classList.add("text-red-500");

      el.setAttribute("onclick",
        `handleLike(this, ${tweetId}, ${count + 1}, true)`
      );
    }

  } catch (err) {
    console.error("Like error:", err);
  }
}

async function handleRetweet(el, tweetId, count, isRetweeted) {
  const token = localStorage.getItem("accessToken");
  const countEl = el.querySelector("span");

  try {
    if (isRetweeted) {
      // UNDO RETWEET
      await fetch(`/retweets/${tweetId}`, {
        method: "DELETE",
        headers: {
          "Authorization": "Bearer " + token
        }
      });

      countEl.innerText = Number(count) - 1;
      el.classList.remove("text-green-500");

      el.setAttribute("onclick",
        `handleRetweet(this, ${tweetId}, ${count - 1}, false)`
      );

    } else {
      // RETWEET
      await fetch(`/retweets/${tweetId}`, {
        method: "POST",
        headers: {
          "Authorization": "Bearer " + token
        }
      });

      countEl.innerText = Number(count) + 1;
      el.classList.add("text-green-500");

      el.setAttribute("onclick",
        `handleRetweet(this, ${tweetId}, ${count + 1}, true)`
      );
    }

  } catch (err) {
    console.error("Retweet error:", err);
  }
}


// POST TWEET
document.getElementById("postBtn").addEventListener("click", async () => {
  const content = document.getElementById("tweetInput").value;

  if (!content.trim()) return;

  await fetch("/tweets", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "Authorization": "Bearer " + token
    },
    body: JSON.stringify({ content })
  });

  document.getElementById("tweetInput").value = "";
  loadFeed();
});

function goToProfile(username) {
  window.location.href = `/api/users/${username}`;
}

document.addEventListener("DOMContentLoaded", () => {
  loadFeed();
});

// ================= SEARCH FEATURE =================

let searchTimeout;

document.getElementById("searchInput").addEventListener("input", (e) => {
  const query = e.target.value.trim();

  clearTimeout(searchTimeout);

  if (!query) {
    document.getElementById("searchResults").classList.add("hidden");
    return;
  }

  searchTimeout = setTimeout(() => {
    performSearch(query);
  }, 400);
});


// 🔍 FETCH SEARCH
async function performSearch(query) {
  try {
    const res = await fetch(`/search?q=${query}`, {
      headers: {
        Authorization: "Bearer " + localStorage.getItem("accessToken")
      }
    });

    const data = await res.json();
    renderSearchResults(data);

  } catch (err) {
    console.error("Search error:", err);
  }
}


//  RENDER RESULTS
function renderSearchResults(data) {
  const container = document.getElementById("searchResults");
  container.innerHTML = "";
  container.classList.remove("hidden");

  //  PEOPLE
  if (data.users.length) {
    container.innerHTML += `
      <div class="p-3 text-gray-500 text-sm">People</div>
    `;

    data.users.forEach(user => {
      container.innerHTML += `
        <div onclick="goToProfile('${user.username}')"
             class="flex items-center gap-3 p-3 hover:bg-[#080808] cursor-pointer">

          <img src="${user.profile_image || 'https://ui-avatars.com/api/?name=' + user.username}"
               class="w-10 h-10 rounded-full"/>

          <div>
            <p class="font-bold">${user.display_name}</p>
            <p class="text-gray-500 text-sm">@${user.username}</p>
          </div>

        </div>
      `;
    });
  }

  //  TWEETS
  if (data.tweets.length) {
    container.innerHTML += `
      <div class="p-3 text-gray-500 text-sm border-t border-gray-800">Tweets</div>
    `;

    data.tweets.forEach(tweet => {
      container.innerHTML += `
        <div onclick="goToTweet(${tweet.tweet_id})"
             class="p-3 border-b border-gray-800 hover:bg-[#080808] cursor-pointer">

          <div class="flex gap-2">
            <img src="${tweet.profile_image  || 'https://ui-avatars.com/api/?name=' + tweet.username}"
                 class="w-8 h-8 rounded-full"/>

            <div>
              <p class="text-sm">
                <span class="font-bold">${tweet.display_name}</span>
                <span class="text-gray-500">@${tweet.username}</span>
              </p>
              <p class="text-sm">${tweet.content}</p>
            </div>
          </div>

        </div>
      `;
    });
  }

  if (!data.users.length && !data.tweets.length) {
    container.innerHTML = `
      <div class="p-4 text-center text-gray-500">
        No results found
      </div>
    `;
  }
}


// NAVIGATION
function goToProfile(username) {
  window.location.href = `/api/users/${username}`;
}

function goToTweet(tweetId) {
  window.location.href = `/api/tweet/${tweetId}`;
}


// 🔥 CLOSE DROPDOWN
document.addEventListener("click", (e) => {
  if (!e.target.closest("#searchInput") && !e.target.closest("#searchResults")) {
    document.getElementById("searchResults").classList.add("hidden");
  }
});

// INITIAL LOAD
loadSidebar();
loadFeed();  
</script>

</body>
