<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile</title>

  <script src="/js/sidebar.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-black text-white">
<div id="followModal"
     class="fixed inset-0 bg-black bg-opacity-70 hidden justify-center items-center z-50">

  <div class="bg-black border border-gray-800 w-[400px] max-h-[500px] rounded-xl overflow-y-auto">

    <!-- HEADER -->
    <div class="p-4 border-b border-gray-800 flex justify-between">
      <h2 id="modalTitle" class="font-bold text-lg"></h2>
      <button onclick="closeFollowModal()">✖</button>
    </div>

    <!-- LIST -->
    <div id="followList"></div>

  </div>
</div>

<!-- EDIT PROFILE MODAL -->
<div id="editProfileModal"
     class="fixed inset-0 bg-black bg-opacity-70 hidden justify-center items-center z-50">

  <div class="bg-black border border-gray-800 w-[500px] max-h-[600px] rounded-xl overflow-y-auto">

    <!-- HEADER -->
    <div class="p-4 border-b border-gray-800 flex justify-between items-center">
      <h2 class="font-bold text-lg">Edit Profile</h2>
      <button onclick="closeEditProfileModal()">✖</button>
    </div>

    <!-- FORM -->
    <form id="editProfileForm" class="p-4 space-y-4">

      <!-- Profile Image -->
      <div>
        <label class="block text-sm text-gray-500 mb-1">Profile Image</label>
        <input type="file" name="profileImage" id="profileImageInput" accept="image/*"
               class="w-full p-2 rounded bg-[#202327] text-sm">
      </div>

      <!-- Cover Image -->
      <div>
        <label class="block text-sm text-gray-500 mb-1">Cover Image</label>
        <input type="file" name="coverImage" id="coverImageInput" accept="image/*"
               class="w-full p-2 rounded bg-[#202327] text-sm">
      </div>

      <!-- Bio -->
      <div>
        <label class="block text-sm text-gray-500 mb-1">Bio</label>
        <textarea id="bioInput" name="bio" rows="3"
                  class="w-full p-2 rounded bg-[#202327] text-sm"
                  placeholder="Tell us about yourself"></textarea>
      </div>

      <!-- Country -->
      <div>
        <label class="block text-sm text-gray-500 mb-1">Country</label>
        <select id="countryInput" name="country"
                class="w-full p-2 rounded bg-[#202327] text-sm">
          <option value="">Select Country</option>
          <option value="US">United States</option>
          <option value="UK">United Kingdom</option>
          <option value="CA">Canada</option>
          <option value="AU">Australia</option>
          <option value="IN">India</option>
          <option value="DE">Germany</option>
          <option value="FR">France</option>
          <option value="JP">Japan</option>
          <option value="BR">Brazil</option>
          <option value="MX">Mexico</option>
          <option value="ES">Spain</option>
          <option value="IT">Italy</option>
          <option value="NL">Netherlands</option>
          <option value="SE">Sweden</option>
          <option value="NO">Norway</option>
          <option value="DK">Denmark</option>
          <option value="FI">Finland</option>
          <option value="NZ">New Zealand</option>
          <option value="SG">Singapore</option>
          <option value="OTHER">Other</option>
        </select>
      </div>

      <!-- Date of Birth -->
      <div>
        <label class="block text-sm text-gray-500 mb-1">Date of Birth</label>
        <input type="date" id="dobInput" name="dob"
               class="w-full p-2 rounded bg-[#202327] text-sm">
      </div>

      <!-- Submit Button -->
      <button type="submit"
              class="w-full bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded-full">
        Save Changes
      </button>

    </form>

  </div>
</div>

<div class="flex max-w-[1300px] mx-auto">

  <!-- LEFT SIDEBAR -->
 <div id="sidebar" class="hidden md:block"></div>
  

  <!-- MAIN -->
  <div class="flex-1 max-w-[600px] border-x border-gray-800">

    <!-- HEADER -->
    <div class="p-4 border-b border-gray-800 flex items-center gap-4">
      <button onclick="window.history.back()">←</button>
      <div>
        <h2 id="name" class="font-bold text-lg"></h2>
        <p id="tweetCount" class="text-gray-500 text-sm"></p>
      </div>
    </div>

    <!-- COVER -->
    <div class="h-40 bg-gray-700" id="cover"></div>

    <!-- PROFILE SECTION -->
    <div class="p-4">

<div class="flex justify-between items-center">
        <img id="profileImg"
             class="w-24 h-24 rounded-full border-4 border-black -mt-12 object-cover"/>

        <button id="followBtn"
  class="border px-4 py-1 rounded-full text-sm hidden">
</button>
      </div>

      <div class="mt-3">
        <h2 id="displayName" class="text-xl font-bold"></h2>
        <p id="username" class="text-gray-500"></p>

        <p id="bio" class="mt-2 text-sm"></p>

        <div class="text-gray-500 text-sm mt-2">
          <span id="country"></span> · 
          <span id="joined"></span>
        </div>

        <div class="mt-2 text-sm flex gap-4">

  <span onclick="openFollowModal('following')" class="cursor-pointer hover:underline">
    <b id="followingCount">0</b> Following
  </span>

  <span onclick="openFollowModal('followers')" class="cursor-pointer hover:underline">
    <b id="followersCount">0</b> Followers
  </span>

</div>

     <!-- TABS -->
<div class="flex justify-around border-b border-gray-800 mt-4 text-sm font-medium">
  <div id="tab-posts" onclick="switchTab('posts')" 
       class="p-3 cursor-pointer border-b-2 border-blue-500">
    Posts
  </div>
  <div id="tab-comments" onclick="switchTab('comments')" 
       class="p-3 cursor-pointer text-gray-500 border-black">
    Comments
  </div>
  <div id="tab-likes" onclick="switchTab('likes')" 
       class="p-3 cursor-pointer text-gray-500 border-black">
    Likes
  </div>
</div>

<!-- CONTENT -->
<div id="tabContent"></div>

      <!-- USER TWEETS -->
      <div id="userTweets"></div>

    </div>
  </div>


</div>

<script>
  
  let profileUserId = null;
const token = localStorage.getItem("accessToken");
const currentUser = JSON.parse(localStorage.getItem("user"));

// username from URL
const username = window.location.pathname.split("/").pop();

let currentTab = "posts";

let isFollowing = false;

async function openFollowModal(type) {
  const modal = document.getElementById("followModal");
  const list = document.getElementById("followList");
  const title = document.getElementById("modalTitle");

  modal.classList.remove("hidden");
  modal.classList.add("flex");

  list.innerHTML = "Loading...";

  let endpoint = "";

  if (type === "followers") {
    title.innerText = "Followers";
    endpoint = `/follows/${profileUserId}/followers`;
  }

  if (type === "following") {
    title.innerText = "Following";
    endpoint = `/follows/${profileUserId}/following`;
  }

  try {
    const res = await fetch(endpoint, {
      headers: { Authorization: "Bearer " + token }
    });

    const data = await res.json();

    renderFollowList(data);

  } catch (err) {
    console.error(err);
    list.innerHTML = "Failed to load";
  }
}

function closeFollowModal() {
  document.getElementById("followModal").classList.add("hidden");
}

function renderFollowList(users) {
  const list = document.getElementById("followList");
  list.innerHTML = "";

  if (!users.length) {
    list.innerHTML = `
      <div class="text-center text-gray-500 p-6">
        Nothing here yet
      </div>
    `;
    return;
  }

  users.forEach(user => {
    const div = document.createElement("div");

    div.className = "flex items-center gap-3 p-4 border-b border-gray-800 hover:bg-[#080808] cursor-pointer";

    div.onclick = () => {
      window.location.href = `/users/${user.username}`;
    };

    div.innerHTML = `
      <img src="${user.profile_image || 'https://ui-avatars.com/api/?name=' + user.username}"
           class="w-10 h-10 rounded-full"/>

      <div>
        <p class="font-bold">${user.display_name}</p>
        <p class="text-gray-500 text-sm">@${user.username}</p>
      </div>
    `;

    list.appendChild(div);
  });
}

function switchTab(tab) {
  currentTab = tab;

  // reset styles
  ["posts", "comments", "likes"].forEach(t => {
    const el = document.getElementById("tab-" + t);
    el.classList.remove("border-blue-500", "text-white", "text-gray-500", "border-b-2");
    el.classList.add("text-gray-500");
  });

  // activate selected
  const active = document.getElementById("tab-" + tab);
  active.classList.add("border-b-2", "border-blue-500", "text-white");
  active.classList.remove("text-gray-500");

  loadTabData();  
}

//  LOAD DATA BASED ON TAB
async function loadTabData() {
  let endpoint = "";

  if (currentTab === "posts") endpoint = `/users/${username}/tweets`;
  if (currentTab === "comments") endpoint = `/users/${username}/comments`;
  if (currentTab === "likes") endpoint = `/users/${username}/likes`;

  try {
    const res = await fetch(endpoint, {
      headers: { Authorization: "Bearer " + token }
    });

    const data = await res.json();
    renderContent(data);

  } catch (err) {
    console.error(err);
  }
}

async function loadFollowCounts() {
  try {
    if (!profileUserId) return;

    const [followersRes, followingRes] = await Promise.all([
      fetch(`/follows/${profileUserId}/followers`, {
        headers: { Authorization: "Bearer " + token }
      }),
      fetch(`/follows/${profileUserId}/following`, {
        headers: { Authorization: "Bearer " + token }
      })
    ]);

    const followers = await followersRes.json();
    const following = await followingRes.json();

    document.getElementById("followersCount").innerText = followers.length;
    document.getElementById("followingCount").innerText = following.length;

  } catch (err) {
    console.error("Follow count error:", err);
  }
}

//  RENDER CONTENT
function renderContent(data) {
  const container = document.getElementById("tabContent");
  container.innerHTML = "";

  if (!data || data.length === 0) {
    container.innerHTML = `
      <div class="text-center text-gray-500 py-10">
        Nothing here yet
      </div>
    `;
    return;
  }

  data.forEach(item => {
    const div = document.createElement("div");
    div.className = "border-b border-gray-800 p-4 flex gap-3";

    // COMMENT UI
    if (currentTab === "comments") {
      div.innerHTML = `
        <img src="${item.profile_image || 'https://ui-avatars.com/api/?name=' + item.username}"
             class="w-10 h-10 rounded-full"/>

        <div class="w-full">
          <p class="font-bold">${item.display_name}</p>
          <p class="text-gray-500 text-sm">@${item.username}</p>

          <p class="mt-2">${item.content}</p>

          <div class="mt-2 text-gray-500 text-sm">
            ❤️ ${item.like_count}
          </div>
        </div>
      `;
    }

    // POSTS & LIKES (TWEET UI)
    else {
      div.innerHTML = `
        <img src="${item.profile_image || 'https://ui-avatars.com/api/?name=' + item.username}"
             class="w-10 h-10 rounded-full"/>

        <div class="w-full">

          ${item.type === "retweet" ? `
            <div class="text-xs text-gray-500 mb-1">🔁 Retweeted</div>
          ` : ""}

          <div class="flex justify-between items-center">
  <div>
    <span class="font-bold">${item.display_name}</span>
    <span class="text-gray-500 ml-1">@${item.username}</span>
  </div>

  ${currentUser?.username === item.username ? `
    <button 
      onclick="deleteTweet(${item.tweet_id})"
      class="text-red-500 text-sm hover:underline">
      Delete
    </button>
  ` : ""}
</div>

          <p class="mt-2">${item.content || ""}</p>

          ${item.media_url ? `
            <img src="${item.media_url}" 
                 class="mt-3 rounded-xl max-h-[400px] w-full object-cover"/>
          ` : ""}

          <div class="flex justify-between mt-3 text-gray-500 text-sm max-w-[400px]">

            <!-- Retweet -->
            <div onclick="handleRetweet(this, ${item.tweet_id}, ${item.retweet_count}, ${item.isRetweeted || false})"
                 class="cursor-pointer ${item.isRetweeted ? 'text-green-500' : ''}">
              🔁 ${item.retweet_count}
            </div>

            <!-- Like -->
            <div onclick="handleLike(this, ${item.tweet_id}, ${item.like_count}, ${item.isLiked || false})"
                 class="cursor-pointer ${item.isLiked ? 'text-red-500' : ''}">
              ❤️ ${item.like_count}
            </div>

          </div>
        </div>
      `;
    }

    container.appendChild(div);
  });
}

async function deleteTweet(tweetId) {
  const token = localStorage.getItem("accessToken");

  const confirmDelete = confirm("Delete this tweet?");
  if (!confirmDelete) return;

  try {
    const res = await fetch(`/tweets/${tweetId}`, {
      method: "DELETE",
      headers: {
        Authorization: "Bearer " + token
      }
    });

    const data = await res.json();

    if (!res.ok) {
      alert(data.message || "Failed to delete");
      return;
    }

    // 🔥 Reload profile tab
    loadTabData();

  } catch (err) {
    console.error("Delete error:", err);
  }
}

// ❤️ LIKE (same as feed)
async function handleLike(el, tweetId, count, isLiked) {
  const countText = el.innerText.split(" ")[1];

  if (isLiked) {
    await fetch(`/reactions/tweets/${tweetId}`, { method: "DELETE", headers: { Authorization: "Bearer " + token } });
    el.innerHTML = `❤️ ${count - 1}`;
    el.classList.remove("text-red-500");
    el.setAttribute("onclick", `handleLike(this, ${tweetId}, ${count - 1}, false)`);
  } else {
    await fetch(`/reactions/tweets/${tweetId}`, { method: "POST", headers: { Authorization: "Bearer " + token } });
    el.innerHTML = `❤️ ${count + 1}`;
    el.classList.add("text-red-500");
    el.setAttribute("onclick", `handleLike(this, ${tweetId}, ${count + 1}, true)`);
  }
}


// 🔁 RETWEET
async function handleRetweet(el, tweetId, count, isRetweeted) {
  if (isRetweeted) {
    await fetch(`/retweets/${tweetId}`, { method: "DELETE", headers: { Authorization: "Bearer " + token } });
    el.innerHTML = `🔁 ${count - 1}`;
    el.classList.remove("text-green-500");
    el.setAttribute("onclick", `handleRetweet(this, ${tweetId}, ${count - 1}, false)`);
  } else {
    await fetch(`/retweets/${tweetId}`, { method: "POST", headers: { Authorization: "Bearer " + token } });
    el.innerHTML = `🔁 ${count + 1}`;
    el.classList.add("text-green-500");
    el.setAttribute("onclick", `handleRetweet(this, ${tweetId}, ${count + 1}, true)`);
  }
}

async function loadUserProfile() {
  console.log("hiii");
  
  try {
    const res = await fetch(`/users/${username}`, {
      headers: {
        Authorization: "Bearer " + token
      }
    });
    
    const user = await res.json();
    profileUserId = user.user_id;
    profileUserId = user.user_id;

// 🔥 HANDLE BUTTON VISIBILITY
const btn = document.getElementById("followBtn");

// If viewing own profile → hide button
if (currentUser?.username === user.username) {
  btn.style.display = "none";
} else {
  btn.style.display = "block";
  checkFollowStatus(); // check if already following
}

    console.log("USER DATA:", user);

    // TEXT DATA
    document.getElementById("displayName").innerText = user.display_name;
    document.getElementById("username").innerText = "@" + user.username;
    document.getElementById("bio").innerText = user.bio || "";
    document.getElementById("country").innerText = user.country || "";
    document.getElementById("joined").innerText = new Date(user.created_at).toDateString();

    // 🔥 PROFILE IMAGE FIX
    console.log(user.profile_image);
    
    document.getElementById("profileImg").src =
      user.profile_image || `https://ui-avatars.com/api/?name=${user.username}`;

    // 🔥 COVER IMAGE FIX (IMPORTANT)
    if (user.cover_photo) {
      document.getElementById("cover").style.backgroundImage = `url(${user.cover_photo})`;
      document.getElementById("cover").style.backgroundSize = "cover";
      document.getElementById("cover").style.backgroundPosition = "center";
    }

  } catch (err) {
    console.error("Profile load error:", err);
  }
}

document.addEventListener("DOMContentLoaded", async () => {
  loadSidebar();
  await loadUserProfile();
  loadFollowCounts();
  loadTabData();
});

async function checkFollowStatus() {
  try {
    const res = await fetch(`/follows/${currentUser.user_id}/following`, {
      headers: { Authorization: "Bearer " + token }
    });

    const following = await res.json();

    isFollowing = following.some(u => u.user_id === profileUserId);

    updateFollowButton();

  } catch (err) {
    console.error("Follow status error:", err);
  }
}


function updateFollowButton() {
  const btn = document.getElementById("followBtn");

  if (isFollowing) {
    btn.innerText = "Following";
    btn.classList.add("bg-white", "text-black");
    btn.classList.remove("border");
  } else {
    btn.innerText = "Follow";
    btn.classList.remove("bg-white", "text-black");
    btn.classList.add("border");
  }

  btn.onclick = toggleFollow;
}
async function toggleFollow() {
  try {
    if (isFollowing) {
      // UNFOLLOW
      await fetch(`/follows/${profileUserId}`, {
        method: "DELETE",
        headers: { Authorization: "Bearer " + token }
      });

      isFollowing = false;

    } else {
      // FOLLOW
      await fetch(`/follows/${profileUserId}`, {
        method: "POST",
        headers: { Authorization: "Bearer " + token }
      });

      isFollowing = true;
    }

    updateFollowButton();
    loadFollowCounts(); // 🔥 update counts instantly

  } catch (err) {
    console.error("Follow error:", err);
  }
}


// Edit Profile Modal Functions
function openEditProfileModal() {
  const modal = document.getElementById("editProfileModal");
  modal.classList.remove("hidden");
  modal.classList.add("flex");

  // Pre-fill form with current user data
  const user = currentUser || {};
  
  document.getElementById("bioInput").value = user.bio || "";
  document.getElementById("countryInput").value = user.country || "";
  document.getElementById("dobInput").value = user.dob || "";
}

function closeEditProfileModal() {
  const modal = document.getElementById("editProfileModal");
  modal.classList.add("hidden");
  modal.classList.remove("flex");
}

// Handle Profile Update Form Submission
document.getElementById("editProfileForm").addEventListener("submit", async (e) => {
  e.preventDefault();

  const bio = document.getElementById("bioInput").value;
  const country = document.getElementById("countryInput").value;
  const dob = document.getElementById("dobInput").value;
  const profileImageFile = document.getElementById("profileImageInput").files[0];
  const coverImageFile = document.getElementById("coverImageInput").files[0];

  const userId = profileUserId;

  try {
    // Update text fields (dob, bio, country)
    if (bio || country || dob) {
      const res = await fetch(`/users/${userId}`, {
        method: "PUT",
        headers: {
          "Content-Type": "application/json",
          Authorization: "Bearer " + token
        },
        body: JSON.stringify({ dob, bio, country })
      });

      if (!res.ok) {
        const err = await res.json();
        alert(err.message || "Failed to update profile");
        return;
      }
    }

    // Upload Profile Image
    if (profileImageFile) {
      const formData = new FormData();
      formData.append("profileImage", profileImageFile);

      const profileRes = await fetch(`/users/${userId}/profile-image`, {
        method: "POST",
        headers: {
          Authorization: "Bearer " + token
        },
        body: formData
      });

      if (!profileRes.ok) {
        const err = await profileRes.json();
        alert(err.message || "Failed to upload profile image");
        return;
      }
    }

    // Upload Cover Image
    if (coverImageFile) {
      const formData = new FormData();
      formData.append("coverImage", coverImageFile);

      const coverRes = await fetch(`/users/${userId}/cover-image`, {
        method: "POST",
        headers: {
          Authorization: "Bearer " + token
        },
        body: formData
      });

      if (!coverRes.ok) {
        const err = await coverRes.json();
        alert(err.message || "Failed to upload cover image");
        return;
      }
    }

    alert("Profile updated successfully!");
    closeEditProfileModal();

    // Reload the profile to show updated data
    await loadUserProfile();

    // Update localStorage user object
    const updatedUser = { ...currentUser, bio, country, dob };
    localStorage.setItem("user", JSON.stringify(updatedUser));

  } catch (err) {
    console.error("Update profile error:", err);
    alert("Failed to update profile");
  }
});

document.addEventListener("DOMContentLoaded", async () => {
  loadSidebar();
  await loadUserProfile();
  loadFollowCounts();
  loadTabData();
});
</script>

</body>
</html>