<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign in to X</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'x-black': '#000000',
                        'x-white': '#ffffff',
                        'x-gray': '#71767b',
                        'x-dark-gray': '#202327',
                        'x-border': '#2f3336',
                        'x-blue': '#1d9bf0',
                        'x-blue-hover': '#1a8cd8',
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
        .input-field {
            width: 100%;
            padding: 20px 0 8px 0;
            background: transparent;
            border: none;
            border-bottom: 1px solid #2f3336;
            color: #fff;
            font-size: 16px;
            outline: none;
        }
        .input-field:focus {
            border-bottom: 1px solid #1d9bf0;
        }
        .input-field::placeholder {
            color: #71767b;
        }
    </style>
</head>
<body class="text-x-white min-h-screen bg-x-black">
    <div class="flex min-h-screen">
        <!-- Left Side - X Logo -->
        <div class="hidden md:flex md:flex-[0.5] lg:flex-[0.4] items-center justify-center p-10">
            <svg class="w-64 h-64 fill-x-white" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
            </svg>
        </div>

        <!-- Right Side - Sign In Form -->
        <div class="flex-1 flex flex-col items-center justify-center p-5">
            <div class="w-full max-w-[400px]">
                <!-- X Logo for mobile -->
                <svg class="w-10 h-10 fill-x-white md:hidden mb-6" viewBox="0 0 24 24">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
                </svg>

                <h1 class="text-[31px] font-bold mb-8">Sign in to X</h1>

                <!-- 2-Column Layout -->
                <div class="grid md:grid-cols-2 gap-6">
                    <!-- Column 1: Username/Email -->
                    <div>
                        <form id="signinFormCol1">
                            <div class="relative">
                                <input type="text" id="identifier" name="identifier" required
                                    class="input-field peer" placeholder=" ">
                                <label for="identifier" class="absolute left-0 top-4 text-x-gray pointer-events-none transition-all duration-200 peer-focus:-translate-y-4 peer-focus:text-x-blue peer-focus:text-xs peer-[:not(:placeholder-shown)]:-translate-y-4 peer-[:not(:placeholder-shown)]:text-xs">email or username
                                </label>
                            </div>
                        </form>
                    </div>
                    <br>

                    <!-- Column 2: Password + Captcha -->
                    <div>
                        <form id="signinFormCol2">
                            <div class="relative">
                                <input type="password" id="password" name="password" required
                                    class="input-field peer" placeholder=" ">
                                <label for="password" class="absolute left-0 top-4 text-x-gray pointer-events-none transition-all duration-200 peer-focus:-translate-y-4 peer-focus:text-x-blue peer-focus:text-xs peer-[:not(:placeholder-shown)]:-translate-y-4 peer-[:not(:placeholder-shown)]:text-xs">
                                    Password
                                </label>
                            </div>

                            <!-- Captcha -->
                            <div class="mt-6 p-4 border border-x-border rounded-lg bg-[#15202b]">
                                <div class="flex items-center gap-4">
                                    <img id="captchaImage" src="" alt="Captcha" class="h-12 border border-x-border rounded">
                                    <button type="button" id="refreshCaptcha" class="text-x-blue hover:text-x-blue-hover text-sm font-semibold">
                                        ↻
                                    </button>
                                </div>
                                <input type="text" id="captchaText" name="captchaText" required
                                    class="input-field mt-3" placeholder="Enter the characters above">
                                <input type="hidden" id="captchaId" name="captchaId">
                            </div>

                            <!-- Sign In Button -->
                            <button type="submit" id="signinBtn"
                                class="w-full mt-6 rounded-full bg-x-white text-x-black font-bold text-[17px] py-3 px-4 transition-colors">
                                Sign in
                            </button>
                        </form>
                    </div>
                </div>

                <div class="mt-8 text-x-gray text-[15px]">
                    Don't have an account? <a href="/auth/signup" class="text-x-blue no-underline hover:underline">Sign up</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        let captchaId = '';
        let captchaData = '';

        // Fetch captcha on page load
        async function loadCaptcha() {
            try {
                const response = await fetch('/auth/captcha');
                const data = await response.json();
                captchaId = data.captchaId;
                captchaData = data.captcha;
                document.getElementById('captchaImage').src = captchaData;
                document.getElementById('captchaId').value = captchaId;
                
            } catch (error) {
                console.error('Error loading captcha:', error);
            }
        }

        // Refresh captcha
        document.getElementById('refreshCaptcha').addEventListener('click', loadCaptcha);

        // Load captcha on page load
        loadCaptcha();

        // Enable/disable submit button based on form validity
        const formCol1 = document.getElementById('signinFormCol1');
        const formCol2 = document.getElementById('signinFormCol2');
        const submitBtn = document.getElementById('signinBtn');
        const identifierInput = document.getElementById('identifier');
        const passwordInput = document.getElementById('password');
        const captchaTextInput = document.getElementById('captchaText');

        function checkFormValidity() {
            const identifier = identifierInput.value;
            const password = passwordInput.value;
            const captchaText = captchaTextInput.value;

        }

        identifierInput.addEventListener('input', checkFormValidity);
        passwordInput.addEventListener('input', checkFormValidity);
        captchaTextInput.addEventListener('input', checkFormValidity);

        // Form submission
        formCol2.addEventListener('submit', async function(e) {
            e.preventDefault();

            const submitBtn = document.getElementById('signinBtn');
            // submitBtn.disabled = true;
            submitBtn.textContent = 'Signing in...';

            const formData = {
                identifier: document.getElementById('identifier').value,
                password: document.getElementById('password').value,
                captchaId: document.getElementById('captchaId').value,
                captchaText: document.getElementById('captchaText').value
            };

            try {
                
                const response = await fetch('/auth/signin', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });

                const result = await response.json();

                if (response.status == 200) {
                    localStorage.setItem('accessToken', result.accessToken);
console.log(result.user_id);

localStorage.setItem("user", JSON.stringify({
    user_id : result.user_id,
  username: result.username,
  display_name: result.display_name,
  profile_image: result.profile_image
}));
                    window.location.href = '/home';
                } else {
                    showError(result.message || 'Invalid credentials');
                    loadCaptcha();
                    document.getElementById('captchaText').value = '';
                }
            } catch (error) {
                console.error('Error:', error);
                showError('Network error. Please try again.');
            }

            submitBtn.textContent = 'Sign in';
            submitBtn.disabled = false;
        });

        function showError(msg) {
            let el = document.getElementById('signin-error');
            if (!el) {
                el = document.createElement('div');
                el.id = 'signin-error';
                el.className = 'mt-4 p-3 rounded-lg bg-red-900/30 border border-red-500 text-red-400 text-sm';
                document.getElementById('signinBtn').insertAdjacentElement('afterend', el);
            }
            el.textContent = msg;
        }
    </script>
</body>
</html>
